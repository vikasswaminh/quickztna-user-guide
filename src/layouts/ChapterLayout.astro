---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  topic: string;
}

const { title, topic } = Astro.props;

const allChapters = await getCollection('chapters');
const sorted = allChapters.sort((a, b) => a.data.order - b.data.order);

// Group by topic
const groups = sorted.reduce<Record<string, typeof sorted>>((acc, ch) => {
  const t = ch.data.topic;
  if (!acc[t]) acc[t] = [];
  acc[t].push(ch);
  return acc;
}, {});
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — QuickZTNA User Guide</title>
    <meta name="description" content={`QuickZTNA manual testing guide: ${title}`} />
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
  </head>
  <body class="bg-slate-950 text-slate-200 min-h-screen flex flex-col">

    <!-- Top nav -->
    <header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/90 backdrop-blur">
      <div class="flex items-center justify-between px-4 h-14 max-w-[1400px] mx-auto">
        <a href="/" class="flex items-center gap-2 text-sky-400 font-bold text-lg tracking-tight hover:text-sky-300 transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          QuickZTNA User Guide
        </a>
        <div id="search-container" class="w-64 hidden md:block"></div>
      </div>
    </header>

    <div class="flex flex-1 max-w-[1400px] mx-auto w-full">
      <!-- Sidebar -->
      <aside class="w-64 shrink-0 border-r border-slate-800 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto sidebar-scroll hidden lg:block">
        <Sidebar groups={groups} currentTitle={title} />
      </aside>

      <!-- Main content -->
      <main class="flex-1 min-w-0 px-6 lg:px-12 py-10" data-pagefind-body>
        <!-- Breadcrumb -->
        <div class="text-sm text-slate-500 mb-6 flex items-center gap-2">
          <a href="/" class="hover:text-sky-400 transition-colors">Home</a>
          <span>›</span>
          <span class="text-sky-500">{topic}</span>
          <span>›</span>
          <span class="text-slate-300">{title}</span>
        </div>

        <h1 class="text-3xl font-bold text-white mb-8 leading-tight">{title}</h1>

        <article class="prose prose-invert prose-slate max-w-3xl prose-headings:scroll-mt-20 prose-a:text-sky-400 prose-code:text-sky-300 prose-pre:bg-slate-900 prose-pre:border prose-pre:border-slate-700">
          <slot />
        </article>
      </main>
    </div>

    <script is:inline>
      // Initialize Pagefind search
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof PagefindUI !== 'undefined') {
          new PagefindUI({
            element: '#search-container',
            showSubResults: false,
            showImages: false,
          });
        }
      });
    </script>
  </body>
</html>
