---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const allChapters = await getCollection('chapters');
const sorted = allChapters.sort((a, b) => a.data.order - b.data.order);

const groups = sorted.reduce<Record<string, typeof sorted>>((acc, ch) => {
  const t = ch.data.topic;
  if (!acc[t]) acc[t] = [];
  acc[t].push(ch);
  return acc;
}, {});

const topicColors: Record<string, string> = {
  'WireGuard': 'from-sky-500 to-blue-600',
  'Access Control': 'from-violet-500 to-purple-600',
  'DNS': 'from-emerald-500 to-teal-600',
  'Authentication': 'from-amber-500 to-orange-600',
  'Posture': 'from-rose-500 to-red-600',
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>QuickZTNA User Guide — Manual Testing Guide</title>
    <meta name="description" content="Step-by-step manual testing guide for QuickZTNA. Real machines, real commands, real verification." />
  </head>
  <body class="bg-slate-950 text-slate-200 min-h-screen">

    <!-- Hero -->
    <div class="border-b border-slate-800 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950">
      <div class="max-w-4xl mx-auto px-6 py-20 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-sky-800 bg-sky-950/50 text-sky-400 text-sm mb-6">
          <span class="w-2 h-2 rounded-full bg-sky-400 animate-pulse"></span>
          Manual Testing Guide
        </div>
        <h1 class="text-5xl font-bold text-white mb-4 leading-tight">
          QuickZTNA<br /><span class="text-sky-400">User Guide</span>
        </h1>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto mb-8">
          Real-world manual testing for every QuickZTNA feature. Real machines, real CLI commands, real verification. Built for your team.
        </p>

        <!-- Test machine legend -->
        <div class="inline-flex items-center gap-4 px-5 py-3 rounded-xl bg-slate-900 border border-slate-700 text-sm">
          <span class="text-slate-500 text-xs uppercase tracking-wide font-semibold">Test Machines:</span>
          <span class="flex items-center gap-1.5 px-2 py-1 rounded bg-blue-900/40 text-blue-300 border border-blue-700 font-mono text-xs">⊞ Win-A <span class="text-blue-500">India/NAT</span></span>
          <span class="flex items-center gap-1.5 px-2 py-1 rounded bg-purple-900/40 text-purple-300 border border-purple-700 font-mono text-xs">⊞ Win-B <span class="text-purple-500">Europe/NAT</span></span>
          <span class="flex items-center gap-1.5 px-2 py-1 rounded bg-emerald-900/40 text-emerald-300 border border-emerald-700 font-mono text-xs">🐧 Linux-C <span class="text-emerald-500">Cloud/Public</span></span>
        </div>
      </div>
    </div>

    <!-- Chapter groups -->
    <div class="max-w-4xl mx-auto px-6 py-16">
      {Object.entries(groups).map(([topic, chapters]) => {
        const gradient = topicColors[topic] ?? 'from-slate-600 to-slate-700';
        return (
          <div class="mb-14">
            <div class="flex items-center gap-3 mb-6">
              <div class={`w-1 h-8 rounded-full bg-gradient-to-b ${gradient}`}></div>
              <h2 class="text-xl font-bold text-white">{topic}</h2>
              <span class="text-xs text-slate-600 font-mono">{chapters.length} chapters</span>
            </div>
            <div class="grid gap-3">
              {chapters.map((ch) => (
                <a
                  href={`/chapters/${ch.id}`}
                  class="flex items-start gap-4 p-4 rounded-xl border border-slate-800 bg-slate-900/40 hover:bg-slate-800/60 hover:border-slate-700 transition-all group"
                >
                  <span class="text-2xl font-bold text-slate-700 group-hover:text-slate-500 transition-colors w-8 text-right shrink-0">{ch.data.order}</span>
                  <div class="flex-1">
                    <div class="font-semibold text-slate-200 group-hover:text-white transition-colors mb-1">{ch.data.title}</div>
                    {ch.data.summary && (
                      <div class="text-sm text-slate-500">{ch.data.summary}</div>
                    )}
                    <div class="flex gap-2 mt-2">
                      {ch.data.machines.map((m) => (
                        <span class="text-xs font-mono text-slate-600 bg-slate-800 px-1.5 py-0.5 rounded">{m}</span>
                      ))}
                    </div>
                  </div>
                  <svg class="w-4 h-4 text-slate-600 group-hover:text-sky-400 shrink-0 mt-0.5 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>

    <footer class="border-t border-slate-800 py-8 text-center text-sm text-slate-600">
      QuickZTNA User Guide — Updated daily
    </footer>
  </body>
</html>
